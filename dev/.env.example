# Application Platform env (M1). Reuse the EXISTING live projects behind
# techrig-form / boc3-form-new (ADR-6) — pull the real values from those repos'
# Vercel project settings. Do NOT commit real secrets; this file documents the
# keys only. The one genuinely new credential is FMCSA_WEBKEY.

# Supabase (DB + Auth) — same project as the legacy apps, new tables added
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel KV (rate limiting + DGR daily reference counter) — same namespace
KV_REST_API_URL=
KV_REST_API_TOKEN=

# HMAC secret for pre-account lead resume tokens (reuse the legacy value so
# existing tokens stay valid)
LEAD_ACCESS_TOKEN_SECRET=

# FMCSA QCMobile backup lookup webKey — NEW credential to obtain (free):
# register at https://mobile.fmcsa.dot.gov/QCDevsite/docs/apiAccess
FMCSA_WEBKEY=

# Stripe (M4) — reuse the legacy account; TEST keys until launch.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email lifecycle (M6). Resend API key (server-only) + the verified sender.
RESEND_API_KEY=
# From address on a Resend-verified domain, e.g. "Tech Rig <hello@techrig.org>".
# Defaults to the Resend sandbox sender if unset.
EMAIL_FROM=
# Shared secret guarding /api/cron/reminders. Vercel cron sends it as a Bearer
# token automatically when this env var is set on the project.
CRON_SECRET=
